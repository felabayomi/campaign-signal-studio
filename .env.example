# OpenAI report generation
# Copy to .env and fill with your real values.

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_REPORT_MODEL=gpt-4o-mini

# Optional provider override: openai or deterministic
# REPORT_PROVIDER=openai

# If false, report generation fails when OpenAI fails.
# If true (default), backend falls back to deterministic output.
OPENAI_FALLBACK_TO_DETERMINISTIC=true

# Trial + auth defaults
TRIAL_DAYS=7
TRIAL_REPORT_LIMIT=5
TRIAL_USER_LIMIT=2
TRIAL_WORKSPACE_LIMIT=1
PASSWORD_HASH_ROUNDS=12

# Stripe billing keys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Optional Stripe recurring price IDs (recommended in production)
# If omitted, checkout falls back to inline monthly prices.
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_xxx
STRIPE_PRICE_CONSULTANT_MONTHLY=price_xxx
STRIPE_PRICE_ONBOARDING_ONETIME=price_xxx

# ElectionPredictor background intelligence
# Reads latest snapshot from incoming/ElectionPredictor by default.
ELECTION_PREDICTOR_INTEL_ENABLED=true
# Optional override path to ElectionPredictor backup directory
# ELECTION_PREDICTOR_BACKUP_PATH=C:\\FelixPlatform\\incoming\\ElectionPredictor\\ElectionPredictor\\database\\backups

# Shared Neon Postgres database (recommended for deployed/shared environments)
# Use one of these; NEON_DATABASE_URL is preferred for clarity.
# Optional explicit provider override: neon | sqlite
# DB_PROVIDER=neon
# Recommended explicit secure mode:
NEON_DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=verify-full
# Optional libpq-compat behavior:
# NEON_DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?uselibpqcompat=true&sslmode=require
# DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=verify-full
